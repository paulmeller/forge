# Local dev defaults. Copy to .env.local and fill in.

DATABASE_URL=file:./local.db
# DATABASE_AUTH_TOKEN=  # required for remote Turso, omit for local libSQL

BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
# forge-web dev server runs on :3100 (see apps/web package.json)
BETTER_AUTH_URL=http://localhost:3100

# Execution backend: managed-agents (default) or gateway
FORGE_BACKEND=managed-agents

# Required for the chat console (always) and for FORGE_BACKEND=managed-agents
# ANTHROPIC_API_KEY=sk-ant-...

# Chat model, as provider:model-id. Defaults to anthropic:claude-sonnet-4-6.
# FORGE_CHAT_MODEL=anthropic:claude-sonnet-4-6

# Optional: route Anthropic calls through a proxy (e.g. AgentStep:
# https://www.agentstep.com/anthropic with your AgentStep key).
# Note: the proxy sees your API key and all request/response traffic.
# ANTHROPIC_BASE_URL=

# Required if FORGE_BACKEND=gateway
# GATEWAY_URL=http://localhost:8787
